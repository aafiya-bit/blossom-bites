<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Menu Item</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="container">
      <div class="card admin-card">
        <h1>Edit Menu Item</h1>
        <form action="/edit-item/<%= item._id %>" method="POST" class="add-item-form">
          <label for="name">Item Name:</label>
          <input type="text" id="name" name="name" value="<%= item.name %>" required />

          <label for="description">Description:</label>
          <textarea
            id="description"
            name="description"
            rows="4"
            required
          ><%= item.description %></textarea>

          <label for="price">Price (₹):</label>
          <input
            type="number"
            id="price"
            name="price"
            step="0.01"
            value="<%= item.price %>"
            required
          />

          <label for="image">Image URL:</label>
          <input
            type="text"
            id="image"
            name="image"
            value="<%= item.image %>"
            required
          />

          <label for="category">Category:</label>
          <select id="category" name="category" required>
            <option value="drinks" <%= item.category === 'drinks' ? 'selected' : '' %>>Drinks</option>
            <option value="snacks" <%= item.category === 'snacks' ? 'selected' : '' %>>Snacks</option>
            <option value="lunch" <%= item.category === 'lunch' ? 'selected' : '' %>>Lunch</option>
            <option value="desserts" <%= item.category === 'desserts' ? 'selected' : '' %>>Desserts</option>
          </select>

          <button type="submit" class="btn">Update Item</button>
          <a href="/manage-items" class="btn btn-secondary">Cancel</a>
        </form>
      </div>
    </div>
  </body>
</html>
