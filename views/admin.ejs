<head>
  <title>Admin Login - Blossom Bites</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>

<header>
  <div class="header-content">
    <a href="admin-login" class="logo">
      <i class="fas fa-utensils"></i>
      <h1>Blossom Bites</h1>
    </a>
    <div class="user-actions">
      <a href="/login" class="btn btn-secondary" id="home-btn">User Login</a>
    </div>
  </div>
</header>

<div class="container">
  <div id="admin-login" class="screen active">
    <div class="admin-login-header">
      <h1>Admin Portal</h1>
      <p>Access the administrative dashboard</p>
    </div>

    <div class="error-message" id="error-message"></div>

    <div class="card">
      <form id="admin-login-form" method="post" action="/admin-login">
        <div class="form-group">
          <label for="admin-email">Admin Email</label>
          <input type="email" id="admin-email" name="email" placeholder="Enter admin email" required />
        </div>

        <div class="form-group">
          <label for="admin-password">Password</label>
          <input type="password" id="admin-password" name="password" placeholder="Enter admin password" required />
        </div>

        <div class="form-group">
          <label for="admin-key">Security Key</label>
          <input type="password" id="admin-key" name="adminKey" placeholder="Enter security key" required />
        </div>

        <div class="form-footer">
          <div class="remember-me">
            <input type="checkbox" id="remember" name="remember" />
            <label for="remember">Remember this device</label>
          </div>
        </div>

        <button type="submit" class="btn btn-admin" style="width: 100%">
          Admin Login
        </button>
      </form>
    </div>
  </div>
</div>

<footer>
  <div class="footer-content">
    <p>© 2025 Blossom Bites Canteen. All rights reserved.</p>
  </div>
</footer>